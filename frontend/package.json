{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"docs:generate": "node ./scripts/generate-openapi-docs.mjs",
		"dev": "CHOKIDAR_USEPOLLING=1 pnpm docs:generate && CHOKIDAR_USEPOLLING=1 vite dev",
		"build": "pnpm docs:generate && vite build",
		"preview": "vite preview",
		"prepare": "pnpm docs:generate && svelte-kit sync || echo ''",
		"check": "pnpm docs:generate && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "pnpm docs:generate && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@internationalized/date": "^3.11.0",
		"@lucide/svelte": "^0.575.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.2.1",
		"@types/canvas-confetti": "^1.9.0",
		"@types/d3": "^7.4.3",
		"autoprefixer": "^10.4.27",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"mode-watcher": "^1.1.0",
		"postcss": "^8.5.8",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"svelte-sonner": "^1.0.8",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"yaml": "^2.8.2"
	},
	"dependencies": {
		"axios": "^1.13.6",
		"canvas-confetti": "^1.9.4",
		"chart.js": "^4.5.1",
		"d3": "^7.9.0",
		"lucide-svelte": "^0.576.0",
		"svelte-chartjs": "^3.1.5",
		"zod": "^4.3.6"
	}
}
